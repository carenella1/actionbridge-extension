{
  "manifest_version": 3,
  "name": "ActionBridge",
  "version": "1.0",
  "description": "Extract action items from highlighted text",
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "host_permissions": [
  "https://*.workers.dev/*"
],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}